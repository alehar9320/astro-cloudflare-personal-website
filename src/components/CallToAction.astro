---
interface Props {
  href: string;
  target?: string;
  rel?: string;
}

const { href, target, rel } = Astro.props;
---

<a href={href} target={target} rel={rel}><slot /></a>

<style>
  a {
    position: relative;
    display: flex;
    place-content: center;
    text-align: center;
    padding: 0.56em 2em;
    gap: 0.8em;
    color: var(--accent-text-over);
    text-decoration: none;
    line-height: 1.1;
    border-radius: 999rem;
    overflow: hidden;
    background-image: var(--gradient-accent-orange);
    background-size: 300% 300%;
    background-position: 0% 50%;
    box-shadow: var(--shadow-md);
    white-space: nowrap;
    transition:
      background-position 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;
  }

  @media (min-width: 20em) {
    a {
      font-size: var(--text-lg);
    }
  }

  a:hover,
  a:focus-visible {
    background-position: 100% 50%;
    transform: translateY(-3px) scale(1.02);
    box-shadow:
      0 12px 30px -5px hsla(210, 100%, 50%, 0.6),
      var(--shadow-md);
  }

  a:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 4px;
  }

  a:active {
    background-position: 50% 50%;
    transform: translateY(0) scale(0.97);
    box-shadow: var(--shadow-sm);
  }

  /* Overlay for standard static hover effect no longer needed, using animated gradient */
  a::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    transition: background-color var(--theme-transition);
    mix-blend-mode: overlay;
  }

  @media (min-width: 50em) {
    a {
      padding: 1.125rem 2.5rem;
      font-size: var(--text-xl);
    }
  }
</style>
