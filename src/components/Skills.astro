---
import Icon from './Icon.astro';
import flags from '../content/flags.json';
---

<section class={`box skills ${flags.enable_skills_pulse_v1 ? 'pulse-enabled' : ''}`}>
  <div class="stack gap-2 lg:gap-4">
    <Icon icon="rocket-launch" color="var(--accent-regular)" size="2.5rem" gradient />
    <h2>Driving Growth & ROI</h2>
    <p>
      Defining and scaling B2B platforms from inception to wide-scale adoption. By focusing on
      high-leverage opportunities, I consistently deliver exponential <a
        href="https://en.wikipedia.org/wiki/Return_on_investment"
        target="_blank"
        rel="noopener noreferrer">ROI</a
      > and measurable business impact.
    </p>
  </div>
  <div class="stack gap-2 lg:gap-4">
    <Icon icon="terminal-window" color="var(--accent-regular)" size="2.5rem" gradient />
    <h2>Accelerating Engineering Strategy</h2>
    <p>
      Bridging the gap between product vision and technical reality. I champion Developer Experience
      (DevEx) and agile execution to dramatically accelerate <a
        href="https://en.wikipedia.org/wiki/Time_to_market"
        target="_blank"
        rel="noopener noreferrer">time-to-market</a
      > for massive-scale AI initiatives.
    </p>
  </div>
  <div class="stack gap-2 lg:gap-4">
    <Icon icon="strategy" color="var(--accent-regular)" size="2.5rem" gradient />
    <h2>Leading Strategic Transformation</h2>
    <p>
      Distilling ambiguous enterprise realities into clear, actionable product roadmaps. I align
      cross-functional teams to optimize resources, drive continuous innovation, and secure
      sustained market leadership.
    </p>
  </div>
</section>

<style>
  .box {
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    padding: 1.5rem;
    background-color: var(--gray-999_40);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition:
      transform var(--theme-transition),
      box-shadow var(--theme-transition),
      border-color var(--theme-transition);
  }

  .box:hover {
    transform: translateY(-4px);
    border-color: var(--accent-regular);
    box-shadow:
      0 12px 30px -5px hsla(210, 100%, 45%, 0.3),
      var(--shadow-md);
  }

  @media (prefers-reduced-motion: reduce) {
    .box {
      transition: none;
    }
    .box:hover {
      transform: none;
    }
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .skills h2 {
    font-size: var(--text-lg);
  }

  .skills p {
    color: var(--gray-400);
  }
  @media (prefers-reduced-motion: no-preference) {
    .pulse-enabled .stack:hover :global(svg) {
      animation: pulse 0.6s ease;
    }
  }
  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  @media (min-width: 50em) {
    .box {
      border-radius: 1.5rem;
      padding: 2.5rem;
    }

    .skills {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5rem;
    }

    .skills h2 {
      font-size: var(--text-2xl);
    }
  }
</style>
