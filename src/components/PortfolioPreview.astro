---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
const flagsEntry = await getEntry('flags', 'config');
const isTactileEnabled = flagsEntry?.data.portfolio_tactile_v1 ?? false;
const isShimmerEnabled = flagsEntry?.data.portfolio_shimmer_v1 ?? false;
---

<a
  class={`card ${isTactileEnabled ? 'tactile' : ''} ${isShimmerEnabled ? 'shimmer' : ''}`}
  href={`/work/${id}`}
>
  <span class="title">{data.title}</span>
  <img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
</a>

<style>
  .card {
    display: grid;
    grid-template: auto 1fr / auto 1fr;
    height: 11rem;
    background: hsla(var(--gray-999-basis), 0.05);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    border: 1px solid hsla(var(--gray-999-basis), 0.2);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    font-family: var(--font-brand);
    font-size: var(--text-lg);
    font-weight: 500;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.4s ease,
      border-color 0.4s ease;
  }

  .card:hover,
  .card:focus-visible {
    transform: translateY(-6px);
    box-shadow:
      0 15px 35px -5px hsla(210, 100%, 45%, 0.4),
      var(--shadow-lg);
    border-color: hsla(var(--gray-999-basis), 0.5);
  }

  .card.tactile:active {
    transform: translateY(2px) scale(0.98);
    transition: transform 0.2s ease;
  }

  .card:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 4px;
  }

  /* Shimmer micro-interaction */
  .card.shimmer {
    position: relative;
  }

  .card.shimmer::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      hsla(var(--gray-999-basis), 0.15) 50%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .card.shimmer:hover::after {
    animation: shimmer-sweep 1s ease-in-out;
  }

  @keyframes shimmer-sweep {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(200%);
    }
  }

  .title {
    grid-area: 1 / 1 / 2 / 2;
    z-index: 1;
    margin: 0.5rem;
    padding: 0.5rem 1rem;
    background: hsla(var(--gray-999-basis), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid hsla(var(--gray-999-basis), 0.1);
    color: var(--gray-200);
    border-radius: 0.375rem;
  }

  img {
    grid-area: 1 / 1 / 3 / 3;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 50em) {
    .card {
      height: 22rem;
      border-radius: 1.5rem;
    }

    .title {
      border-radius: 0.9375rem;
    }
  }
</style>
