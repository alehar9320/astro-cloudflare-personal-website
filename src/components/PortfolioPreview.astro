---
import type { CollectionEntry } from 'astro:content';
import { DelightSchema } from '../content/schemas/delights';
import delightsFlags from '../content/delights.json';

interface Props {
  project: CollectionEntry<'work'>;
}
const { data, id } = Astro.props.project;
const { shimmer } = DelightSchema.parse(delightsFlags);
---

<a class:list={['card', { shimmer }]} href={`/work/${id}`}>
  <span class="title">{data.title}</span>
  <img src={data.img} alt={data.img_alt || ''} loading="lazy" />
</a>
<style>
  .card {
    display: grid;
    grid-template: auto 1fr / auto 1fr;
    height: 11rem;
    background: hsla(var(--gray-999-basis), 0.05);
    backdrop-filter: blur(16px) saturate(140%);
    border: 1px solid hsla(var(--gray-999-basis), 0.2);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    font-family: var(--font-brand);
    font-size: var(--text-lg);
    font-weight: 500;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.4s ease;
  }
  .card:hover,
  .card:focus-visible {
    transform: translateY(-6px);
    box-shadow:
      0 15px 35px -5px hsla(210, 100%, 45%, 0.4),
      var(--shadow-lg);
  }
  .card:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 4px;
  }
  .shimmer::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: translateX(-100%);
    z-index: 2;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  }
  .shimmer:hover::before {
    animation: shimmer 1.2s infinite;
  }
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .title {
    grid-area: 1 / 1 / 2 / 2;
    z-index: 1;
    margin: 0.5rem;
    padding: 0.5rem 1rem;
    background: hsla(var(--gray-999-basis), 0.85);
    backdrop-filter: blur(12px);
    border: 1px solid hsla(var(--gray-999-basis), 0.1);
    color: var(--gray-200);
    border-radius: 0.375rem;
  }
  img {
    grid-area: 1 / 1 / 3 / 3;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (min-width: 50em) {
    .card {
      height: 22rem;
      border-radius: 1.5rem;
    }
    .title {
      border-radius: 0.9375rem;
    }
  }
</style>
