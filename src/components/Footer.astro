---
import Icon from './Icon.astro';
import versionData from '../data/version.json';

const currentYear = new Date().getFullYear();
---

<footer>
  <div class="group">
    <p>
      Designed & Developed in Sweden with <a href="https://astro.build/">Astro</a>
      <Icon icon="rocket-launch" size="1.2em" />
    </p>
    <p>&copy; {currentYear} Alexander Härenstam</p>
    <p><a href="/whats-new" class="version-link">v{versionData.version}</a></p>
  </div>
  <p class="socials">
    <a href="https://www.linkedin.com/in/alehar/"> LinkedIn</a>
    <a href="https://blog.ifs.com/author/alexander-harenstam/"> IFS Blog</a>
    <a href="https://github.com/alehar9320"> GitHub</a>
    <a
      href="https://github.com/alehar9320/astro-cloudflare-personal-website"
      aria-label="View source code for this site"
      class="source-link"
    >
      <Icon icon="github-logo" />
      <span class="sr-only">Source</span>
    </a>
  </p>
</footer>
<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: auto;
    padding: 3rem 2rem 3rem;
    text-align: center;
    color: var(--gray-400);
    font-size: var(--text-sm);
  }

  footer a {
    color: var(--gray-400);
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  footer a:hover,
  footer a:focus {
    text-decoration-color: currentColor;
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .version-link {
    font-family: var(--font-brand);
    font-size: var(--text-sm);
    color: var(--gray-400);
    text-decoration: none;
    transition: color var(--theme-transition);
  }

  .version-link:hover,
  .version-link:focus {
    color: var(--gray-200);
  }

  /* Source icon link styling: keep visual weight minimal */
  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-sm);
  }

  .source-link .sr-only {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 50em) {
    footer {
      flex-direction: row;
      justify-content: space-between;
      padding: 2.5rem 5rem;
    }

    .group {
      flex-direction: row;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .socials {
      justify-content: flex-end;
    }
  }
</style>
