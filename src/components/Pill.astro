---
import { z } from 'zod'; import f from '../content/flags.json';
const s = z.boolean().catch(false).parse(f.enable_pill_shimmer);
---
<div class:list={['pill', { s }]}><slot /></div>
<style>
  .pill { display: flex; padding: 0.5rem 1rem; gap: 0.5rem; color: var(--accent-text-over); border: 1px solid var(--accent-regular); background-color: var(--accent-regular); border-radius: 999rem; font-size: var(--text-md); line-height: 1.35; white-space: nowrap; position: relative; overflow: hidden; background-image: linear-gradient(110deg, var(--accent-regular), var(--gradient-stop-1) 50%, var(--gradient-stop-3)); background-size: 250% 100%; background-position: 0% 50%; box-shadow: var(--shadow-sm); }
  .s::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, hsla(var(--gray-999-basis), 0.2), transparent); animation: s 3s infinite linear; }
  @keyframes s { from { transform: translateX(-100%); } to { transform: translateX(100%); } }
  @media (prefers-reduced-motion) { .s::after { display: none; } }
</style>
