---
import { z } from 'zod';
import flags from '../content/flags.json';

const isHoverEnabled = z.boolean().default(false).parse(flags.pill_hover_v1);
---

<div class={`pill ${isHoverEnabled ? 'interactive' : ''}`}><slot /></div>

<style>
  .pill {
    display: flex;
    padding: 0.5rem 1rem;
    gap: 0.5rem;
    color: var(--accent-text-over);
    border: 1px solid var(--accent-regular);
    background-color: var(--accent-regular);
    border-radius: 999rem;
    font-size: var(--text-md);
    line-height: 1.35;
    white-space: nowrap;

    /* Interactive state base styles */
    background-image: linear-gradient(
      110deg,
      var(--accent-regular) 0%,
      var(--gradient-stop-1) 50%,
      var(--gradient-stop-3) 100%
    );
    background-size: 250% 100%;
    background-position: 0% 50%;
    box-shadow: var(--shadow-sm);
  }

  .pill.interactive {
    transition:
      background-position 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;
  }

  .pill.interactive:hover {
    background-position: 100% 50%;
    transform: translateY(-2px);
    box-shadow:
      0 8px 20px -5px hsla(210, 100%, 50%, 0.4),
      var(--shadow-md);
  }
</style>
