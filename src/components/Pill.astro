---
import { getEntry } from 'astro:content';
const flagsEntry = await getEntry('flags', 'config');
const isInteractionEnabled = flagsEntry?.data.enable_pill_interaction_v1 ?? false;
---

<div class={`pill ${isInteractionEnabled ? 'interactive' : ''}`}><slot /></div>

<style>
  .pill {
    display: flex;
    padding: 0.5rem 1rem;
    gap: 0.5rem;
    color: var(--accent-text-over);
    border: 1px solid var(--accent-regular);
    background-color: var(--accent-regular);
    border-radius: 999rem;
    font-size: var(--text-md);
    line-height: 1.35;
    white-space: nowrap;

    /* Interactive state base styles */
    background-image: linear-gradient(
      110deg,
      var(--accent-regular) 0%,
      var(--gradient-stop-1) 50%,
      var(--gradient-stop-3) 100%
    );
    background-size: 250% 100%;
    background-position: 0% 50%;
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--theme-transition),
      background-position 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow var(--theme-transition);
  }

  .pill.interactive:hover {
    transform: translateY(-2px);
    background-position: 100% 50%;
    box-shadow: var(--shadow-md);
  }

  .pill.interactive:active {
    transform: translateY(0) scale(0.97);
    transition: transform 0.1s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .pill {
      transition: none;
    }
    .pill.interactive:hover,
    .pill.interactive:active {
      transform: none;
    }
  }
</style>
